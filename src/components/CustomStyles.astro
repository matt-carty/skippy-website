---
import '@fontsource-variable/inter';

// 'DM Sans'
// Nunito
// Dosis
// Outfit
// Roboto
// Literata
// 'IBM Plex Sans'
// Karla
// Poppins
// 'Fira Sans'
// 'Libre Franklin'
// Inconsolata
// Raleway
// Oswald
// 'Space Grotesk'
// Urbanist
---

<style is:inline>
  /*
   * Skippy English School — official brand palette
   * Pink #FF00A3 · Light blue #6AE6EE · Purple #9966FF · Dark text #302D55
   * Orange #FF9933 · Standard text #7A7A7A
   */
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(153 102 255);
    /* Darker purple for primary hover / secondary actions */
    --aw-color-secondary: rgb(120 62 230);
    --aw-color-accent: rgb(255 0 163);

    --aw-color-brand-cyan: rgb(106 230 238);
    --aw-color-brand-orange: rgb(255 153 51);

    --aw-color-text-heading: rgb(48 45 85);
    --aw-color-text-default: rgb(122 122 122);
    --aw-color-text-muted: rgb(122 122 122 / 72%);
    --aw-color-text-page: rgb(122 122 122);
    --aw-color-bg-page: rgb(252 253 254);
    /* Wash using light blue */
    --aw-color-surface-soft: rgb(239 251 252);

    --aw-color-bg-page-dark: rgb(26 24 44);

    ::selection {
      background-color: rgb(153 102 255 / 22%);
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(179 153 255);
    --aw-color-secondary: rgb(153 102 255);
    --aw-color-accent: rgb(255 77 176);

    --aw-color-brand-cyan: rgb(140 235 242);
    --aw-color-brand-orange: rgb(255 179 102);

    --aw-color-text-heading: rgb(247 248 248);
    --aw-color-text-default: rgb(212 212 220);
    --aw-color-text-muted: rgb(212 212 220 / 66%);
    --aw-color-text-page: rgb(212 212 220);
    --aw-color-bg-page: rgb(26 24 44);
    --aw-color-surface-soft: rgb(36 34 58);

    ::selection {
      background-color: rgb(153 102 255 / 40%);
      color: rgb(255 255 255);
    }
  }
</style>
